---
import '../styles/global.css';

const currentUser = Astro.locals.currentUser;
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>XIVPedia</title>
	</head>
	<body>
		<nav class="sticky top-0 z-50 border-b bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60">
			<div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4">
				<a href="/" class="text-xl font-bold tracking-tight">XIVPedia</a>
				<div class="flex items-center gap-4">
					{currentUser ? (
						<div class="flex items-center gap-4">
							<span class="text-sm text-muted-foreground">
								{currentUser.profile?.displayName ?? currentUser.email}
							</span>
							<form action="/api/auth/logout" method="POST">
								<button
									type="submit"
									class="rounded-md bg-secondary px-3 py-1.5 text-sm font-medium text-secondary-foreground hover:bg-secondary/80"
								>
									ログアウト
								</button>
							</form>
						</div>
					) : (
						<a
							href="/login"
							class="rounded-md bg-primary px-3 py-1.5 text-sm font-medium text-primary-foreground hover:bg-primary/90"
						>
							ログイン
						</a>
					)}
				</div>
			</div>
		</nav>
		<slot />
	</body>
</html>
