---
import CategoryManagement from '../../components/admin/CategoryManagement.tsx';
import ReportManagement from '../../components/admin/ReportManagement.tsx';
import TagManagement from '../../components/admin/TagManagement.tsx';
import TagRequestManagement from '../../components/admin/TagRequestManagement.tsx';
import UserManagement from '../../components/admin/UserManagement.tsx';
import Layout from '../../layouts/Layout.astro';

const currentUser = Astro.locals.currentUser;

// admin以外はリダイレクト
if (!currentUser || currentUser.profile?.role !== 'admin') {
	return Astro.redirect('/');
}
---

<Layout title="管理画面">
	<div class="py-8 max-w-4xl mx-auto space-y-8">
		<h1 class="text-3xl font-bold text-foreground">管理画面</h1>
		<TagRequestManagement client:idle />
		<CategoryManagement client:idle />
		<TagManagement client:idle />
		<UserManagement client:idle currentUserId={currentUser.id} />
		<ReportManagement client:idle />
	</div>
</Layout>
