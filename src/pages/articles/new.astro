---
import { ArticleEditor } from '../../components/editor/ArticleEditor';
import Layout from '../../layouts/Layout.astro';
import { listCategories } from '../../lib/categories';
import { listTags } from '../../lib/tags';

const { currentUser } = Astro.locals;

if (!currentUser) {
	return Astro.redirect('/login');
}

const [tags, categoryList] = await Promise.all([
	listTags(Astro.locals.db),
	listCategories(Astro.locals.db),
]);
const categories = categoryList.map((c) => ({ slug: c.slug, name: c.name }));
---

<Layout title="記事を作成">
	<div class="py-4">
		<h1 class="text-2xl font-bold mb-6">記事を作成</h1>
		<ArticleEditor client:load mode="new" tags={tags} categories={categories} />
	</div>
</Layout>
