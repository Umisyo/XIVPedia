---
import MobileNav from './MobileNav.tsx';
import NotificationBell from './NotificationBell.tsx';
import SearchBar from './SearchBar.astro';
import UserMenu from './UserMenu.tsx';

const currentUser = Astro.locals.currentUser;
---

<header class="bg-card border-b border-border sticky top-0 z-50" role="banner">
	<div class="container mx-auto px-4 max-w-4xl">
		<div class="flex items-center justify-between h-14">
			<!-- Logo -->
			<a href="/" class="text-primary font-bold text-xl hover:opacity-80 transition-opacity" aria-label="XIVPedia トップページ">
				XIVPedia
			</a>

			<!-- Desktop Navigation -->
			<nav class="hidden md:flex items-center gap-4" aria-label="メインナビゲーション">
				<a
					href="/articles"
					class="text-muted-foreground hover:text-foreground transition-colors"
				>
					記事一覧
				</a>
				<a
					href="/tags"
					class="text-muted-foreground hover:text-foreground transition-colors"
				>
					タグ
				</a>
				<div class="w-48">
					<SearchBar />
				</div>
				{
					currentUser ? (
						<>
							<a
								href="/mypage"
								class="text-muted-foreground hover:text-foreground transition-colors"
							>
								マイページ
							</a>
							<a
								href="/articles/new"
								class="bg-primary text-primary-foreground px-4 py-2 rounded-md
									text-sm font-medium hover:opacity-90 transition-opacity"
							>
								投稿
							</a>
							<NotificationBell client:load />
							<UserMenu
								client:idle
								displayName={currentUser.profile?.displayName ?? currentUser.email}
								avatarUrl={currentUser.profile?.avatarUrl ?? undefined}
								role={currentUser.profile?.role ?? undefined}
							/>
						</>
					) : (
						<a
							href="/login"
							class="bg-primary text-primary-foreground px-4 py-2 rounded-md
								text-sm font-medium hover:opacity-90 transition-opacity"
						>
							ログイン
						</a>
					)
				}
			</nav>

			<!-- Mobile Navigation -->
			<MobileNav
				client:idle
				user={currentUser ? {
					displayName: currentUser.profile?.displayName ?? currentUser.email,
					avatarUrl: currentUser.profile?.avatarUrl ?? undefined,
					role: currentUser.profile?.role ?? undefined,
				} : null}
			/>
		</div>
	</div>
</header>
