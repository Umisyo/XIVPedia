---
interface Props {
	html: string;
}

const { html } = Astro.props;
---

<div class="article-content" set:html={html} />

<style>
	.article-content {
		color: var(--color-foreground);
		line-height: 1.8;
		font-size: 1rem;
	}

	/* Headings */
	.article-content :global(h1) {
		font-size: 2rem;
		font-weight: 700;
		margin-top: 2.5rem;
		margin-bottom: 1rem;
		padding-bottom: 0.5rem;
		border-bottom: 1px solid var(--color-border);
	}

	.article-content :global(h2) {
		font-size: 1.5rem;
		font-weight: 700;
		margin-top: 2rem;
		margin-bottom: 0.75rem;
		padding-bottom: 0.375rem;
		border-bottom: 1px solid var(--color-border);
	}

	.article-content :global(h3) {
		font-size: 1.25rem;
		font-weight: 600;
		margin-top: 1.5rem;
		margin-bottom: 0.5rem;
	}

	.article-content :global(h4) {
		font-size: 1.125rem;
		font-weight: 600;
		margin-top: 1.25rem;
		margin-bottom: 0.5rem;
	}

	/* Paragraphs */
	.article-content :global(p) {
		margin-top: 1rem;
		margin-bottom: 1rem;
	}

	/* Links */
	.article-content :global(a) {
		color: var(--color-primary);
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	.article-content :global(a:hover) {
		opacity: 0.8;
	}

	/* Lists */
	.article-content :global(ul) {
		list-style-type: disc;
		padding-left: 1.5rem;
		margin-top: 0.75rem;
		margin-bottom: 0.75rem;
	}

	.article-content :global(ol) {
		list-style-type: decimal;
		padding-left: 1.5rem;
		margin-top: 0.75rem;
		margin-bottom: 0.75rem;
	}

	.article-content :global(li) {
		margin-top: 0.25rem;
		margin-bottom: 0.25rem;
	}

	.article-content :global(li > ul),
	.article-content :global(li > ol) {
		margin-top: 0.25rem;
		margin-bottom: 0.25rem;
	}

	/* Blockquotes */
	.article-content :global(blockquote) {
		border-left: 4px solid var(--color-primary);
		padding-left: 1rem;
		margin-top: 1rem;
		margin-bottom: 1rem;
		color: var(--color-muted-foreground);
		font-style: italic;
	}

	/* Code - inline */
	.article-content :global(code) {
		background-color: var(--color-secondary);
		padding: 0.125rem 0.375rem;
		border-radius: 0.25rem;
		font-size: 0.875em;
	}

	/* Code - blocks (shiki output) */
	.article-content :global(pre) {
		margin-top: 1.25rem;
		margin-bottom: 1.25rem;
		padding: 1rem;
		border-radius: 0.5rem;
		overflow-x: auto;
		font-size: 0.875rem;
		line-height: 1.6;
	}

	.article-content :global(pre.shiki) {
		border: 1px solid var(--color-border);
	}

	/* Reset inline code style inside pre blocks */
	.article-content :global(pre code) {
		background-color: transparent;
		padding: 0;
		border-radius: 0;
		font-size: inherit;
	}

	/* Tables */
	.article-content :global(table) {
		width: 100%;
		border-collapse: collapse;
		margin-top: 1.25rem;
		margin-bottom: 1.25rem;
		font-size: 0.875rem;
	}

	.article-content :global(thead) {
		border-bottom: 2px solid var(--color-border);
	}

	.article-content :global(th) {
		padding: 0.625rem 0.75rem;
		text-align: left;
		font-weight: 600;
		color: var(--color-foreground);
	}

	.article-content :global(td) {
		padding: 0.625rem 0.75rem;
		border-bottom: 1px solid var(--color-border);
	}

	.article-content :global(tr:hover) {
		background-color: var(--color-secondary);
	}

	/* Horizontal Rule */
	.article-content :global(hr) {
		border: none;
		border-top: 1px solid var(--color-border);
		margin-top: 2rem;
		margin-bottom: 2rem;
	}

	/* Images */
	.article-content :global(img) {
		max-width: 100%;
		height: auto;
		border-radius: 0.5rem;
		margin-top: 1rem;
		margin-bottom: 1rem;
	}

	/* Strong & Emphasis */
	.article-content :global(strong) {
		font-weight: 700;
		color: var(--color-foreground);
	}

	.article-content :global(em) {
		font-style: italic;
	}
</style>
